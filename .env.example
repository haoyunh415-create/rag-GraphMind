# Graph RAG Platform environment template.
# Copy this file to .env before Docker or production-like runs:
#   Copy-Item .env.example .env
#
# Local development can run without .env because the backend has safe defaults.
# Values below are Docker-friendly defaults; replace every "replace-me" secret.

# App
APP_NAME=Graph RAG Platform
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MAX_UPLOAD_BYTES=10485760

# LLM / embeddings
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
LLM_BASE_URL=https://api.openai.com/v1

# Retrieval tuning
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=10
RERANK_TOP_K=5

# Local vector fallback
SQLITE_DB_PATH=data/rag.db

# Milvus
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=documents

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-me

# Elasticsearch
ES_HOST=http://elasticsearch:9200
ES_INDEX=documents

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=replace-me
MINIO_SECRET_KEY=replace-me
MINIO_BUCKET=documents

# Redis
REDIS_URL=redis://redis:6379/0

# Frontend
# Docker compose exposes the backend on host port 8000.
NEXT_PUBLIC_API_URL=http://localhost:8000
