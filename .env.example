# Graph RAG 平台环境变量模板。
# Docker 或类生产环境运行前，请复制为 .env：
#   Copy-Item .env.example .env
#
# 本地开发可以不创建 .env，因为后端带有安全的本地默认值。
# 下面的值适合 Docker 默认网络；部署前请替换所有 "replace-me" 密钥。

# 应用基础配置
APP_NAME=知识图谱 RAG 平台
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_AUTH_TOKEN=replace-me
MAX_UPLOAD_BYTES=10485760

# 大模型与向量模型
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
LLM_BASE_URL=https://api.openai.com/v1

# 检索参数
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=10
RERANK_TOP_K=5
RERANKER_ENABLED=true
RERANKER_ORIGINAL_WEIGHT=0.35
RERANKER_QUERY_WEIGHT=0.45
RERANKER_PHRASE_WEIGHT=0.15
RERANKER_SOURCE_WEIGHT=0.05
CITATION_MAX_ITEMS=3
CITATION_PER_DOCUMENT_LIMIT=2
CITATION_MIN_RELATIVE_SCORE=0.55
CITATION_MIN_QUERY_COVERAGE=0.35
GRAPH_ENTITY_EXTRACTION_ENABLED=true
GRAPH_ENTITY_EXTRACTION_SYNC=true
GRAPH_ENTITY_EXTRACTION_TIMEOUT_SECONDS=20
RETRIEVAL_HEALTH_CACHE_SECONDS=10
TRACE_STEP_BUDGETS_MS=backend_health=500,retrieve=300,rank=100,cite=50,evaluate=100

# 本地向量检索兜底存储
SQLITE_DB_PATH=data/rag.db

# Milvus
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=documents

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-me

# Elasticsearch
ES_HOST=http://elasticsearch:9200
ES_INDEX=documents

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=replace-me
MINIO_SECRET_KEY=replace-me
MINIO_BUCKET=documents

# Redis
REDIS_URL=redis://redis:6379/0
INGESTION_QUEUE_MODE=auto
INGESTION_QUEUE_NAME=rag:ingestion:queue
INGESTION_DLQ_NAME=rag:ingestion:queue:dead
INGESTION_QUEUE_DIR=data/ingestion-uploads
INGESTION_MAX_ATTEMPTS=3
INGESTION_RETRY_DELAY_SECONDS=2

# 前端
# Docker Compose 默认把后端暴露在宿主机 8000 端口。
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_AUTH_TOKEN=replace-me
